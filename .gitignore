# ── Data: exclude unnecessary files ──────────────────────────────
# WISDM: keep raw.txt and about/readme; exclude Windows metadata
WISDM_ar_latest/**/*.Zone.Identifier
WISDM_ar_latest/**/*.arff

# UCI HAR: exclude pre-computed features (not used) and gyroscope signals
human+activity+recognition+using+smartphones/UCI\ HAR\ Dataset/train/X_train.txt
human+activity+recognition+using+smartphones/UCI\ HAR\ Dataset/test/X_test.txt
human+activity+recognition+using+smartphones/UCI\ HAR\ Dataset/train/Inertial\ Signals/body_acc_*.txt
human+activity+recognition+using+smartphones/UCI\ HAR\ Dataset/train/Inertial\ Signals/body_gyro_*.txt
human+activity+recognition+using+smartphones/UCI\ HAR\ Dataset/test/Inertial\ Signals/body_acc_*.txt
human+activity+recognition+using+smartphones/UCI\ HAR\ Dataset/test/Inertial\ Signals/body_gyro_*.txt
human+activity+recognition+using+smartphones/**/*.Zone.Identifier
human+activity+recognition+using+smartphones/__MACOSX/
human+activity+recognition+using+smartphones/*.zip

# Slide preview images (auto-generated)
preview/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
.DS_Store
*.Zone.Identifier
__MACOSX/

# Editors
.vscode/
.idea/

# Windows Zone.Identifier metadata files
**/*.Zone.Identifier
*:Zone.Identifier

# TensorBoard event files (large binary)
results/runs/
results_final/runs/

# Model checkpoints (large binary)
results/checkpoints/
results_final/viz_checkpoints/

# Training logs
results/*.log
results_final/*.log

# Intermediate HP search artifacts (keep JSONs, skip large results)
results/hp_search_results.json

# Python env
.env
venv/
env/

# Large UCI HAR pre-computed feature files (not used, >50 MB)
data/ucihar/UCI HAR Dataset/train/X_train.txt
data/ucihar/UCI HAR Dataset/test/X_test.txt
data/ucihar/*.zip
data/ucihar/UCI HAR Dataset.zip
